# Copy this file to .env (inside frontend/) and uncomment ONE line.
# Leave the file absent (or all lines commented) to use the automatic defaults:
#   - Development (Expo Go / simulator): http://192.168.0.235:8000/api
#   - Production build (EAS / TestFlight): Railway live backend

# ── Point at your local Django backend ───────────────────────────────────────
# iOS Simulator: 127.0.0.1 works fine
# Android Emulator: use 10.0.2.2 instead of 127.0.0.1
# Physical device: use your machine's LAN IP (same subnet as the device)
# EXPO_PUBLIC_API_URL=http://192.168.0.235:8000/api

# ── Point at the live Railway backend (from a dev client) ────────────────────
# EXPO_PUBLIC_API_URL=https://workout-tracker-production-30b3.up.railway.app/api
