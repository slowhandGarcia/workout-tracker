# Copy to .env (in this frontend/ folder) and adjust for your setup.
# Only needed to override the default backend — see lib/api.ts for the
# dev/production fallback logic this controls.
#
# Leave unset to use the live Railway backend automatically in production
# builds, or your machine's LAN IP in dev (edit DEV_FALLBACK_API_URL in
# lib/api.ts to match your machine).
#
# To point at your own local Django backend during development instead:
#   iOS Simulator can reach your Mac via 127.0.0.1.
#   Android Emulator must use 10.0.2.2 instead of 127.0.0.1.
#   A physical device must use your machine's LAN IP (e.g. http://192.168.1.20:8000/api).
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000/api

# To point at the live backend explicitly (e.g. testing against prod from a
# dev client), uncomment instead:
# EXPO_PUBLIC_API_URL=https://workout-tracker-production-30b3.up.railway.app/api
